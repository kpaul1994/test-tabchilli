{
  "sections": {
    "collection-header": {
      "type": "collection-header",
      "settings": {
        "enable": false,
        "collection_image_enable": true,
        "parallax": true,
        "parallax_direction": "top"
      }
    },
    "promo-grid": {
      "type": "promo-grid",
      "blocks": {
        "banner": {
          "type": "banner",
          "settings": {
            "heading": "Save on Select Styles",
            "heading_size": "h3",
            "text": "Take an extra 10% off sale items — limited time",
            "link": "",
            "label": "Shop now",
            "color_tint": "#2a3743",
            "color_tint_opacity": 10,
            "framed": false
          }
        }
      },
      "block_order": ["banner"],
      "settings": {
        "full_width": false,
        "gutter_size": 20,
        "space_above": true,
        "space_below": false
      }
    },
    "main-collection": {
      "type": "main-collection",
      "blocks": {
        "collection_description": {
          "type": "collection_description",
          "settings": {}
        },
        "subcollections": {
          "type": "subcollections",
          "settings": {
            "subcollections_per_row": 5
          }
        },
        "product_grid": {
          "type": "product_grid",
          "settings": {
            "enable_collection_count": true,
            "per_row": 4,
            "rows_per_page": 10,
            "mobile_flush_grid": true
          }
        }
      },
      "block_order": ["collection_description", "subcollections", "product_grid"],
      "settings": {
        "enable_sidebar": true,
        "collapsed": true,
        "filter_style": "drawer",
        "enable_color_swatches": true,
        "enable_swatch_labels": true,
        "enable_sort": true
      }
    }
  },
  "order": ["collection-header", "promo-grid", "main-collection"]
}
